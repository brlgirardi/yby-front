# API base URL — quando vazio ou apontando para "mock", o app usa fixtures locais
# em src/services/mocks/* e nunca toca rede.
#
# DEV oficial Tupi:  https://yby-dev.positivolabs.com.br/v1
# Auth:              POST /v1/auth  { username, password }  →  access_token (5min) + refresh_token (30min)
# Docs:              https://github.com/tupi-fintech/yby-docs
NEXT_PUBLIC_API_BASE_URL=

# "mock" | "real" — força modo. Se vazio, decide pela presença de NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_API_MODE=mock

# Read-only mode — quando "true", botões de ação destrutivos (POST/PUT/DELETE)
# ficam desabilitados na UI. Útil para demos. Default true.
NEXT_PUBLIC_READ_ONLY=true
